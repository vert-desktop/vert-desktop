{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for VERT Desktop",
  "platforms": ["linux", "macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "ffmpeg",  "sidecar": true, "args": true },
        { "name": "magick",  "sidecar": true, "args": true },
        { "name": "pandoc",  "sidecar": true, "args": true }
      ]
    },
    "shell:allow-spawn",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-copy-file",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save"
  ]
}
